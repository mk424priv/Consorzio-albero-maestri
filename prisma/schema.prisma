// Albero Maestri — schema dati (PRD §6)
// Provider: sqlite in sviluppo, postgresql in produzione (Vercel).
// Per restare portabili: enum modellati come String (validati in app),
// importi come Float (arrotondati ai centesimi a video).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Cliente {
  id                 String   @id @default(cuid())
  nome               String
  cognome            String
  inizialiCodice     String // II del codice parlante (es. MR, MR1) — fisso
  telefono           String?
  email              String?
  luogo              String?
  latitudine         Float?
  longitudine        Float?
  tariffaOraria      Float? // €/h propria del cliente
  modalitaPredefinita String  @default("preventivo") // preventivo | ore | misto
  note               String?
  creatoIl           DateTime @default(now())

  lavori       Lavoro[]
  preventivi   Preventivo[]
  ore          RegistrazioneOre[]
  pagamenti    Pagamento[]
  spese        Spesa[]

  @@index([cognome, nome])
}

model Persona {
  id     String  @id @default(cuid())
  nome   String
  ruolo  String  @default("operatore") // titolare | operatore
  attivo Boolean @default(true)

  lavori Lavoro[]
  ore    RegistrazioneOre[]
}

model Lavoro {
  id                String   @id @default(cuid())
  clienteId         String
  cliente           Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  titolo            String
  descrizione       String?
  luogo             String?
  data              DateTime
  ordineNelGiorno   Int?
  stato             String   @default("da_fare") // da_fare | in_corso | fatto
  tipoCompenso      String   @default("preventivo") // preventivo | ore | misto
  durataPrevistaOre Float?
  personaId         String?
  persona           Persona? @relation(fields: [personaId], references: [id], onDelete: SetNull)
  note              String?
  creatoIl          DateTime @default(now())

  preventivi Preventivo[]
  ore        RegistrazioneOre[]
  pagamenti  Pagamento[]
  spese      Spesa[]

  @@index([data])
  @@index([clienteId])
}

model Preventivo {
  id             String   @id @default(cuid())
  clienteId      String
  cliente        Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  lavoroId       String?
  lavoro         Lavoro?  @relation(fields: [lavoroId], references: [id], onDelete: SetNull)
  tipo           String   @default("unico") // unico | acconto_saldo
  importoTotale  Float
  importoAcconto Float?
  importoSaldo   Float?
  dataEmissione  DateTime @default(now())
  note           String?

  pagamenti Pagamento[]

  @@index([clienteId])
}

model RegistrazioneOre {
  id        String   @id @default(cuid())
  clienteId String
  cliente   Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  lavoroId  String?
  lavoro    Lavoro?  @relation(fields: [lavoroId], references: [id], onDelete: SetNull)
  personaId String?
  persona   Persona? @relation(fields: [personaId], references: [id], onDelete: SetNull)
  data      DateTime
  ore       Float
  note      String?

  @@index([clienteId, data])
}

model Pagamento {
  id               String      @id @default(cuid())
  clienteId        String
  cliente          Cliente     @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  lavoroId         String?
  lavoro           Lavoro?     @relation(fields: [lavoroId], references: [id], onDelete: SetNull)
  preventivoId     String?
  preventivo       Preventivo? @relation(fields: [preventivoId], references: [id], onDelete: SetNull)
  origine          String      @default("manuale") // preventivo | acconto | saldo | ore | manuale
  importoAtteso    Float
  importoIncassato Float       @default(0)
  stato            String      @default("in_attesa") // in_attesa | pagato | in_ritardo
  dataEmissione    DateTime    @default(now())
  dataScadenza     DateTime?
  dataIncasso      DateTime?
  note             String?

  @@index([clienteId])
  @@index([stato])
}

model Spesa {
  id          String   @id @default(cuid())
  categoria   String   @default("altro") // benzina | materiali | attrezzi | altro
  importo     Float
  data        DateTime
  descrizione String?
  clienteId   String?
  cliente     Cliente? @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  lavoroId    String?
  lavoro      Lavoro?  @relation(fields: [lavoroId], references: [id], onDelete: SetNull)

  @@index([data])
}

model Attrezzo {
  id            String    @id @default(cuid())
  nome          String
  costoAcquisto Float?
  dataAcquisto  DateTime?
  stato         String    @default("ok") // ok | manutenzione | dismesso
  note          String?
}
