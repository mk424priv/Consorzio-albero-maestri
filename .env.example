# Sincronizzazione cloud (opzionale). Senza queste variabili l'app funziona
# in locale (solo questo browser). Con esse, i dati si sincronizzano tra
# tutti i dispositivi che usano lo stesso VITE_WORKSPACE_ID.

VITE_SUPABASE_URL=https://xxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=la-tua-anon-key
VITE_WORKSPACE_ID=albero
