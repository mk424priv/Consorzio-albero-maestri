# Sincronizzazione multi-dispositivo (OPZIONALE).
# Senza queste variabili l'app è local-first identica (offline, nessun backend).
#
# Per attivarla: crea un progetto su https://supabase.com, esegui supabase/schema.sql
# nel SQL editor, poi valorizza:
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Riconoscimento attrezzo 3D con Gemini (OPZIONALE). Vedi canone/10.
# Senza questa chiave il Garage usa il matcher locale (offline, identico funzionalmente).
# ATTENZIONE: una VITE_* finisce nel bundle pubblico — usare una chiave dedicata e
# restringerla per dominio (HTTP referrer) in Google Cloud Console.
VITE_GEMINI_API_KEY=

# ── Backend proprietario + portale cliente (Blocco E, canone/10) ──
# L'agente esegue TUTTA la configurazione del codice. Questi 3 valori dipendono da un
# account (Neon/Vercel) e li fornisce l'utente: in locale qui, in produzione nelle
# Environment Variables del progetto Vercel. NON sono VITE_* → restano lato server.
#
# Stringa di connessione Postgres (endpoint POOLED di Neon).
DATABASE_URL=postgres://utente:password@host/db?sslmode=require
# Segreto che autentica l'app operatore verso il backend. node -e "console.log(crypto.randomUUID())"
OPERATOR_SECRET=
# Segreto per derivare/validare i token magic-link dei clienti.
TOKEN_SECRET=
